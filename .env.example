# OBLIGATOIRE avant déploiement : générez une longue valeur aléatoire.
SECRET_KEY=change-me-with-a-long-random-secret

# Gemini API - une clé Google AI Studio est nécessaire pour le laboratoire.
# La clé reste uniquement sur le serveur et ne doit jamais être placée dans le JavaScript.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_RETRY_ATTEMPTS=3
PROMPT_ATTEMPT_LIMIT=3

# Chemin de la base SQLite et de la vidéo locale.
DATABASE_PATH=data/mepa.sqlite
LOCAL_VIDEO_PATH=video-introduction-ia.mp4

# Local : false. Production HTTPS : true.
SESSION_COOKIE_SECURE=false

# Activez uniquement derrière un reverse proxy correctement configuré.
TRUST_PROXY=false
FLASK_DEBUG=false
HOST=127.0.0.1
PORT=5000
